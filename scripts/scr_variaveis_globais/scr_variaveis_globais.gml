//variavel para contaar os pontos do player
global.pontos = 0;
//variavel para definir a velocidade de todos os objetos ao mesmo tempo
global.velocidade = 2;
//contador pra saber quando os pontos chegam em dezenas
global.dificultador = 0;
//variavel para saber se já existe uma musica tocando, pra que não toque uma em cima da outra
global.musica_ligada = 0;